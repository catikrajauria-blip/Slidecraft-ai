{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A presentation project containing slides and metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project." },
        "name": { "type": "string", "description": "Name of the project." },
        "createdAt": { "type": "number", "description": "Timestamp when the project was created." },
        "updatedAt": { "type": "number", "description": "Timestamp when the project was last updated." },
        "ownerId": { "type": "string", "description": "UID of the user who owns the project." },
        "originalText": { "type": "string", "description": "The raw text extracted from the PPTX." },
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" },
              "visualSuggestion": { "type": "string" },
              "animationType": { "type": "string" },
              "theme": {
                "type": "object",
                "properties": {
                  "primaryColor": { "type": "string" },
                  "secondaryColor": { "type": "string" },
                  "accentColor": { "type": "string" },
                  "fontFamily": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "required": ["id", "name", "createdAt", "ownerId", "slides"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of presentation projects."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    }
  }
}
